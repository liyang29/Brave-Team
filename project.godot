; Engine configuration file.
; Brave Team — 小队背包 Roguelike（从 Brave Guild 迁出战斗/背包核心）

config_version=5

[application]

config/name="Brave Team"
run/main_scene="res://scenes/ui/TitleScreen.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")

[autoload]

RunManager="*res://scripts/autoload/RunManager.gd"
MetaProgress="*res://scripts/autoload/MetaProgress.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/gut/plugin.cfg")

[rendering]

rendering_device/driver.windows="d3d12"
